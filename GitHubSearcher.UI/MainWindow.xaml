<Window x:Class="GitHubSearcher.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GitHub Repository Searcher" Height="500" Width="850" WindowStartupLocation="CenterScreen" Background="#f3f4f6">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Search Query:" VerticalAlignment="Center" Margin="5" FontWeight="SemiBold"/>
                <TextBox x:Name="SearchBox" Grid.Column="1" Margin="5" Padding="4"/>

                <TextBlock Grid.Column="2" Text="Ignore Word (Opt):" VerticalAlignment="Center" Margin="5" FontWeight="SemiBold"/>
                <TextBox x:Name="IgnoreBox" Grid.Column="3" Margin="5" Padding="4"/>

                <TextBlock Grid.Row="1" Text="Language (Opt):" VerticalAlignment="Center" Margin="5" FontWeight="SemiBold"/>
                <TextBox x:Name="LanguageBox" Grid.Row="1" Grid.Column="1" Margin="5" Padding="4" ToolTip="e.g., csharp, python"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Result Limit:" VerticalAlignment="Center" Margin="5" FontWeight="SemiBold"/>
                <ComboBox x:Name="LimitComboBox" Grid.Row="1" Grid.Column="3" Margin="5" SelectedIndex="1" Padding="4">
                    <ComboBoxItem Content="10"/>
                    <ComboBoxItem Content="30"/>
                    <ComboBoxItem Content="50"/>
                    <ComboBoxItem Content="100"/>
                </ComboBox>

                <TextBlock Grid.Row="2" Text="Sort By:" VerticalAlignment="Center" Margin="5" FontWeight="SemiBold"/>
                <ComboBox x:Name="SortComboBox" Grid.Row="2" Grid.Column="1" Margin="5" SelectedIndex="0" Padding="4">
                    <ComboBoxItem Content="Best Match" Tag=""/>
                    <ComboBoxItem Content="Stars" Tag="stars"/>
                    <ComboBoxItem Content="Forks" Tag="forks"/>
                    <ComboBoxItem Content="Updated" Tag="updated"/>
                    <ComboBoxItem Content="Help Wanted Issues" Tag="help-wanted-issues"/>
                </ComboBox>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="Order:" VerticalAlignment="Center" Margin="5" FontWeight="SemiBold"/>
                <ComboBox x:Name="OrderComboBox" Grid.Row="2" Grid.Column="3" Margin="5" SelectedIndex="0" Padding="4">
                    <ComboBoxItem Content="Descending" Tag="desc"/>
                    <ComboBoxItem Content="Ascending" Tag="asc"/>
                </ComboBox>
            </Grid>

            <CheckBox x:Name="SaveJsonCheckBox" Content="Save raw JSON data to folder" Margin="5,10,5,5" FontWeight="SemiBold" VerticalAlignment="Center"/>

            <Grid Margin="5,10,5,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="SearchButton" Grid.Column="0" Content="Search Repositories" Padding="10,8" Click="SearchButton_Click" Background="#2ea043" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,10,0"/>
                <Button x:Name="ViewLogsButton" Grid.Column="1" Content="View Logs" Padding="15,8" Click="ViewLogsButton_Click" Background="#4b5563" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,10,0"/>
                <Button x:Name="ViewSavedButton" Grid.Column="2" Content="View JSONs" Padding="15,8" Click="ViewSavedButton_Click" Background="#4b5563" Foreground="White" FontWeight="Bold" FontSize="14"/>
            </Grid>

            <TextBlock x:Name="StatusText" Text="Ready to search." Margin="5,0,5,0" Foreground="Gray" FontStyle="Italic"/>
        </StackPanel>

        <DataGrid x:Name="ResultsDataGrid" 
                  Grid.Row="1" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  AlternatingRowBackground="#eef2f5" 
                  HeadersVisibility="Column"
                  MouseDoubleClick="ResultsDataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Repository Name" Binding="{Binding Name}" Width="2*"/>
                <DataGridTextColumn Header="Language" Binding="{Binding Language}" Width="*"/>
                <DataGridTextColumn Header="Stars" Binding="{Binding Stars}" Width="0.8*"/>
                <DataGridTextColumn Header="Forks" Binding="{Binding Forks}" Width="0.8*"/>
                <DataGridTextColumn Header="Issues" Binding="{Binding OpenIssues}" Width="0.8*"/>
                <DataGridTextColumn Header="Last Updated" Binding="{Binding LastUpdated, StringFormat=\{0:yyyy-MM-dd\}}" Width="1.2*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>